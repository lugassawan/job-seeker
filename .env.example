# OpenWeb Ninja API key for JSearch (https://app.openwebninja.com)
OPENWEBNINJA_API_KEY=your_openwebninja_api_key_here

# Alternative API key for JSearch (used only if OPENWEBNINJA_API_KEY is unset)
# RAPIDAPI_KEY=your_rapidapi_key_here

# Google Service Account JSON (base64-encoded)
GOOGLE_SERVICE_ACCOUNT_KEY=base64_encoded_service_account_json

# Google Sheets spreadsheet ID (from the URL)
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# Sheet tab name (defaults to "Jobs")
GOOGLE_SHEET_NAME=Jobs
